{
  "version": 2,
  "buildCommand": "prisma generate && next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "/api/v1/:path*"
    }
  ],
  "functions": {
    "app/api/v1/**/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
