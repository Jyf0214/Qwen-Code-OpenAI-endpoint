{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "rewrites": [
    {
      "source": "/v1/(.*)",
      "destination": "/api/v1/$1"
    }
  ],
  "functions": {
    "src/index.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "frontend/app/api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
